<?xml version="1.0" encoding="utf-8"?>
<!-- Disable all cloud backup and device transfer for AndroDR.
     Security scan data should never leave the device. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
